# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, 15.5
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'FaceRN' do
  pod 'FaceAISDK_Core', :git => 'https://github.com/FaceAISDK/FaceAISDK_Core.git', :tag => '2026.05.28.xcode15'
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    installer.pods_project.build_configurations.each do |config|
      config.build_settings["EXCLUDED_ARCHS[sdk=iphonesimulator*]"] = "arm64"
      config.build_settings["CLANG_ENABLE_MODULES"] = "YES"
    end

    # FaceAISDK_Core requires TensorFlowLiteSwift to have module interface (swiftinterface)
    installer.pods_project.targets.each do |target|
      if target.name == 'TensorFlowLiteSwift'
        target.build_configurations.each do |bc|
          bc.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
          existing = bc.build_settings['OTHER_SWIFT_FLAGS'] || '$(inherited)'
          bc.build_settings['OTHER_SWIFT_FLAGS'] = existing + ' -no-verify-emitted-module-interface'
        end
      end
    end

    # Create module.modulemap for TensorFlowLite so it can be discovered during
    # FaceAISDK_Core swiftinterface processing (Xcc flags are not propagated, but
    # Swift -I paths are used for Clang module discovery in that context)
    tfl_dir = "#{installer.sandbox.root}/Headers/Public/TensorFlowLite"
    modulemap_link = File.join(tfl_dir, "module.modulemap")
    unless File.exist?(modulemap_link)
      File.symlink("TensorFlowLiteSwift.modulemap", modulemap_link)
    end

    # Add Pods/Headers/Public to SWIFT_INCLUDE_PATHS so TensorFlowLite/module.modulemap
    # is discoverable during swiftinterface processing
    pods_headers_public = "#{installer.sandbox.root}/Headers/Public"
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.xcconfigs.each do |config_name, xcconfig|
        existing = xcconfig.attributes['SWIFT_INCLUDE_PATHS'] || '$(inherited)'
        unless existing.include?(pods_headers_public)
          xcconfig.attributes['SWIFT_INCLUDE_PATHS'] = "#{existing} \"#{pods_headers_public}\""
          xcconfig_path = aggregate_target.xcconfig_path(config_name)
          xcconfig.save_as(xcconfig_path)
        end
      end
    end
  end
end

